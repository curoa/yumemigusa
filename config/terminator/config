[global_config]
  suppress_multiple_term_dialog = True
[keybindings]
  go_up = <Primary><Shift>k
  go_down = <Primary><Shift>j
  go_left = <Primary><Shift>h
  go_right = <Primary><Shift>l
  preferences_keybindings = ""
[profiles]
  [[default]]
    background_darkness = 0.85
    background_type = image
    background_image = /home/blackcat/Pictures/image/terminatorbg/22_resize.jpg
    background_image_mode = scale_and_crop
    background_image_align_vert = top
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
